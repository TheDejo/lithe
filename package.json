{
  "name": "lithe",
  "version": "1.0.0",
  "description": "A lightweight TypeScript testing framework",
  "main": "dist/index.js",
  "bin": {
    "lithe": "dist/cli/index.js"
  },
  "scripts": {
    "test": "ts-node src/cli/index.ts examples/*.test.ts",
    "build": "tsc",
    "start": "ts-node src/cli/index.ts",
    "dev": "ts-node src/cli/index.ts test"
  },
  "keywords": [
    "testing",
    "typescript",
    "minimalist"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/node": "^20.4.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
